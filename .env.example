# ─── AquaGuard AI — Configuración de Notificaciones ───────────────
# Copia este archivo como .env y rellena tus credenciales.
# NUNCA subas el .env real a Git.

# ── Telegram ──────────────────────────────────────────────────────
# 1. Habla con @BotFather en Telegram → /newbot
# 2. Copia el token aquí
# 3. Escribe al bot desde tu cuenta → obtén el chat_id con:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Vapi (Llamadas de Voz con IA conversacional) ──────────────────
# 1. Regístrate en https://vapi.ai — plan gratuito disponible
# 2. Crea un Phone Number en el dashboard → copia el ID
# 3. Copia tu API Key
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ── Twilio (Fallback TTS si Vapi no configurado) ──────────────────
# 1. Regístrate en https://twilio.com — trial gratuito ($15 crédito)
# 2. Consola Twilio → Account SID + Auth Token
# 3. Compra un número de teléfono
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Contactos de Escalado ─────────────────────────────────────────
# Número al que llamar cuando se detecta alerta ALTO/CRÍTICO
# Formato internacional: +34XXXXXXXXX
CONTACT_PHONE_NUMBER=

# Número de emergencia si el titular no contesta (alerta CRÍTICO)
# Familiar, servicio social, o equipo de inspección AMAEM
EMERGENCY_CONTACT_PHONE=

# ── Configuración Demo ────────────────────────────────────────────
# true = modo demo: escalado instantáneo (no espera 5 min para llamada 2)
AQUAGUARD_DEMO_MODE=true

# Segundos a esperar antes de escalar al contacto de emergencia
# Demo: 10-30 seg | Producción: 300 (5 min)
ESCALATION_WAIT_SECONDS=30

# ── Uso ───────────────────────────────────────────────────────────
# Solo Telegram:
#   python run_all_models.py --notify-telegram
#
# Telegram + llamada de voz:
#   python run_all_models.py --notify-telegram --notify-voice
#
# Test del notificador:
#   python notifier.py
#
# Verificar cobertura de anomalías:
#   python check_coverage.py --generate-data
